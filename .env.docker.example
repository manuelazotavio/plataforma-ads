# Connection string completa do banco Supabase.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Pasta sincronizada pelo OneDrive no Windows.
ONEDRIVE_BACKUP_DIR=C:/Users/SEU_USUARIO/OneDrive/ADS Conecta/Backups/Supabase

# Um backup por dia e retencao de 14 dias.
BACKUP_INTERVAL_SECONDS=86400
KEEP_DAYS=14
